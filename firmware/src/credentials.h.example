#pragma once

// Copy this file to credentials.h and fill in your values.
// credentials.h is gitignored and will not be committed.

#include "Config.h"

// ============= Server Endpoints =============
// Development: typically `wrangler dev` on your laptop. Use your LAN IP
// (not localhost) since the device connects over WiFi.
constexpr const char *DEVELOPMENT_SERVER_ADDRESS = "10.0.0.10";
constexpr int DEVELOPMENT_SERVER_PORT = 8787;

// Production: your deployed Cloudflare Worker. Always TLS on port 443.
// e.g. "m5-live.your-account.workers.dev"
constexpr const char *PRODUCTION_SERVER_ADDRESS =
    "m5-live.your-account.workers.dev";

// Device tries entries in order and falls back on failure.
constexpr ServerEndpoint SERVER_ENDPOINTS[] = {
    {DEVELOPMENT_SERVER_ADDRESS, DEVELOPMENT_SERVER_PORT, nullptr},
    {PRODUCTION_SERVER_ADDRESS, 443, GTS_ROOT_R4_CA},
};
constexpr int SERVER_ENDPOINT_COUNT =
    sizeof(SERVER_ENDPOINTS) / sizeof(SERVER_ENDPOINTS[0]);

// ============= WiFi Networks =============
const WiFiNetwork WIFI_NETWORKS[] = {
    {"your-home-ssid", "your-home-password", "Home"},
    {"your-work-ssid", "your-work-password", "Work"},
};
constexpr int WIFI_NETWORK_COUNT =
    sizeof(WIFI_NETWORKS) / sizeof(WIFI_NETWORKS[0]);
